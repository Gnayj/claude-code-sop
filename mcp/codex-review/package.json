{
  "name": "@gnayj/ccsop-review-mcp",
  "version": "0.1.0",
  "description": "ccsop review MCP bridge: pluggable design / code / fix review for Claude Code via a ReviewProvider abstraction (codex | claude | manual). Default provider: codex.",
  "private": true,
  "type": "module",
  "main": "dist/server.js",
  "bin": {
    "codex-review-mcp": "dist/server.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "smoke:claude": "node scripts/claude-live-smoke.mjs",
    "smoke:implement": "node scripts/implement-live-smoke.mjs"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.104.1",
    "@iarna/toml": "^2.2.5",
    "@modelcontextprotocol/sdk": "^1.0.4",
    "@openai/codex-sdk": "^0.145.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.7.5",
    "typescript": "^5.6.3",
    "vitest": "^2.1.3"
  },
  "engines": {
    "node": ">=20.10.0"
  }
}
